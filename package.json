{
  "name": "cloudflare-docs-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/cli.ts",
    "serve": "node --import tsx src/cli.ts serve",
    "setup": "node --import tsx src/cli.ts setup",
    "sync": "node --import tsx src/cli.ts sync",
    "status": "node --import tsx src/cli.ts status",
    "devices": "node --import tsx src/cli.ts devices",
    "clients": "node --import tsx src/cli.ts clients",
    "test": "vitest run"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.7.6",
    "@modelcontextprotocol/sdk": "^1.18.1",
    "better-sqlite3": "^11.10.0",
    "commander": "^14.0.1",
    "express": "^5.1.0",
    "gray-matter": "^4.0.3",
    "onnxruntime-node": "^1.21.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
